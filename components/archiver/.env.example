MQTT_HOST=mosquitto
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=true
MQTT_CA_FILE=/etc/ssl/certs/ca-certificates.crt
# Development only: permits MQTT_TLS=false.
ALLOW_INSECURE_MQTT=false
MQTT_BASE_TOPIC=lora-tracker
ARCHIVER_ID=home
DATABASE_PATH=/data/lora-tracker-history.sqlite3
RETENTION_DAYS=10
# Empty means all trackers. Otherwise comma-separated 16-character hashes.
TRACKER_HASHES=
RESPONSE_CHUNK_POINTS=25
MAXIMUM_REQUEST_POINTS=500
LOG_LEVEL=INFO
