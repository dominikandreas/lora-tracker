MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_BASE_TOPIC=equine
ARCHIVER_ID=home
DATABASE_PATH=/data/equine-history.sqlite3
RETENTION_DAYS=10
# Empty means all trackers. Otherwise comma-separated 16-character hashes.
TRACKER_HASHES=
RESPONSE_CHUNK_POINTS=25
MAXIMUM_REQUEST_POINTS=500
LOG_LEVEL=INFO
