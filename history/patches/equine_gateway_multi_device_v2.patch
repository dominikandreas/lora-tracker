+#pragma once
+
+#include <stddef.h>
+#include <stdint.h>
+
+// Compile-time gateway and tracker registry.
+//
+// This is intentionally static for protocol step 2. A later configuration
+// step will move these values into a versioned, persistent configuration that
+// can be edited through onboarding without recompiling the firmware.
+
+struct GatewayTrackerConfig {
+  // Stable canonical ID used to derive the public 64-bit routing hash.
+  // Keep this lowercase and do not reuse an ID for a different physical unit.
+  const char* id;
+
+  // Human-readable name used by logs and Home Assistant discovery.
+  const char* name;
+
+  // Map old unversioned LoRa packets to this tracker. At most one registry
+  // entry should set this to true because legacy packets contain no identity.
+  bool accepts_legacy_lora;
+
+  // Also publish the old horse/<id>/... MQTT aliases during migration.
+  bool publish_legacy_mqtt_aliases;
+};
+
+static const char* const GATEWAY_ID = "home";
+static const char* const GATEWAY_NAME = "Home Equine Gateway";
+
+static const GatewayTrackerConfig GATEWAY_TRACKERS[] = {
+  {"wera", "Wera", true, true},
+
+  // Add more protocol-v1 trackers here. Example:
+  // {"hugo", "Hugo", false, false},
+};
+
+static constexpr size_t GATEWAY_TRACKER_COUNT =
+  sizeof(GATEWAY_TRACKERS) / sizeof(GATEWAY_TRACKERS[0]);
+
+static constexpr size_t MAX_GATEWAY_TRACKERS = 12;
+static_assert(GATEWAY_TRACKER_COUNT > 0, "Register at least one tracker");
+static_assert(GATEWAY_TRACKER_COUNT <= MAX_GATEWAY_TRACKERS,
+              "Increase MAX_GATEWAY_TRACKERS or reduce registry size");
