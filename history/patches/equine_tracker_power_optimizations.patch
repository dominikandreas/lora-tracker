+  while (digitalRead(USER_BTN_PIN) == LOW &&
+         (uint32_t)(millis() - hold_start_ms) < WIFI_SETUP_BOOT_HOLD_MS) {
+    delay(10);
+  }
+
+  const bool requested =
+    (uint32_t)(millis() - hold_start_ms) >= WIFI_SETUP_BOOT_HOLD_MS;
+  if (requested) {
+    // Avoid interpreting the same boot-time hold as a normal UI press.
+    previous_button_pressed = true;
+    last_button_event_ms = millis();
+  }
+  return requested;
+}
